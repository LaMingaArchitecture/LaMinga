# Copy to .env and fill with the real values (shared password manager).
# .env is gitignored — never commit secrets.

# Storyblok content-delivery tokens (EU region) — Settings > Access Tokens
STORYBLOK_PUBLIC_TOKEN=
STORYBLOK_PREVIEW_TOKEN=

# Canonical site URL (used by sitemap + canonical links)
PUBLIC_SITE_URL=http://localhost:4321

# Content version is chosen by the run script, not pinned here:
#   pnpm dev          -> published content (Public token)
#   pnpm dev:preview  -> draft content + visual-editor bridge (Preview token)
# Leaving STORYBLOK_VERSION unset lets the inline script value win; astro:env
# defaults to 'published'.

# Online only (Netlify preview site): HTTP Basic-Auth for the gated preview deploy.
# Not used locally. Format: "user:password" (exactly one colon). Use a long,
# high-entropy generated secret — the gate has no rate limiting.
# PREVIEW_BASIC_AUTH=
