# Copy to .env and fill with the real values (shared password manager).
# .env is gitignored — never commit secrets.

# Storyblok content-delivery tokens (EU region) — Settings > Access Tokens
STORYBLOK_PUBLIC_TOKEN=
STORYBLOK_PREVIEW_TOKEN=

# Canonical site URL (used by sitemap + canonical links)
PUBLIC_SITE_URL=http://localhost:4321

# 'published' = prod SSG (Public token) | 'draft' = preview SSR (Preview token)
STORYBLOK_VERSION=published
