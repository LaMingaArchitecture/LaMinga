{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["@netlify/edge-functions"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["edge-functions/**/*.ts"]
}
