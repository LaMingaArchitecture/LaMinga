---
import { renderRichText } from '@storyblok/astro';
import SocialLinks from './SocialLinks.astro';
import type { GlobalSettings } from '../types/storyblok';

interface Props {
  settings: GlobalSettings | null;
}

const { settings } = Astro.props;
const mentions = settings?.mentions_legales ? renderRichText(settings.mentions_legales) : '';
const social = settings?.reseaux_sociaux ?? [];
---

<footer class="site-footer">
  {settings?.nom_atelier && <span class="site-footer__name">{settings.nom_atelier}</span>}
  {
    settings?.email && (
      <a class="site-footer__email" href={`mailto:${settings.email}`}>
        {settings.email}
      </a>
    )
  }
  {
    settings?.telephone && (
      <a class="site-footer__tel" href={`tel:${settings.telephone.replace(/\s+/g, '')}`}>
        {settings.telephone}
      </a>
    )
  }
  {
    settings?.adresse_paris && (
      <address class="site-footer__address" style="white-space: pre-line">
        {settings.adresse_paris}
      </address>
    )
  }
  {
    settings?.adresse_anglet && (
      <address class="site-footer__address" style="white-space: pre-line">
        {settings.adresse_anglet}
      </address>
    )
  }
  <SocialLinks links={social} class="site-footer__social" />
  {mentions && <div class="site-footer__mentions" set:html={mentions} />}
</footer>
