---
import { renderRichText } from '@storyblok/astro';
import type { GlobalSettings } from '../types/storyblok';

interface Props {
  settings: GlobalSettings | null;
}

const { settings } = Astro.props;
const mentions = settings?.footer_mentions ? renderRichText(settings.footer_mentions) : '';
const social = settings?.reseaux_sociaux ?? [];
---

<footer class="site-footer">
  {
    settings?.footer_adresse && (
      <address class="site-footer__address">{settings.footer_adresse}</address>
    )
  }
  {
    settings?.email && (
      <a class="site-footer__email" href={`mailto:${settings.email}`}>
        {settings.email}
      </a>
    )
  }
  {
    social.length > 0 && (
      <ul class="site-footer__social" aria-label="Réseaux sociaux">
        {social.map((link) => (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              {link.plateforme}
            </a>
          </li>
        ))}
      </ul>
    )
  }
  {mentions && <div class="site-footer__mentions" set:html={mentions} />}
</footer>
