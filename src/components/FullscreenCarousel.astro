---
/**
 * FullscreenCarousel — generic, blok-type-agnostic fullscreen scroller.
 * Wraps already-rendered slides via <slot/> (home_slide now, media_slide later), so it owns the
 * scroll-snap track + slide sizing and neither slide type needs to know it's in a carousel.
 * Progressive enhancement: the CSS scroll-snap track works with no JS (native swipe/scroll);
 * `fullscreen-carousel.ts` layers arrows, keyboard nav, ARIA live announcements, lazy video. The
 * controls render at all times — the arrows ship `disabled` (dimmed) and the script enables them
 * once ready — so they show a loading state instead of popping in after load (with no JS they stay
 * disabled while native swipe still works).
 */
import type { HTMLAttributes } from 'astro/types';
import Chevron from './icons/Chevron.astro';

interface Props extends HTMLAttributes<'section'> {
  /** Accessible name for the carousel region (home: "Projets à la une"; project page: the title). */
  ariaLabel: string;
  /** Slide count — renders the counter's N server-side and seeds the script. */
  slideCount: number;
  /** Show the "X / N" counter (project page: true; home: false). */
  counter?: boolean;
  /**
   * Control layout: 'split' (home) = arrows mid-height at the edges, counter bottom-right;
   * 'grouped' (project page) = chevrons flank the counter in one bottom-right ‹ X / N › cluster.
   */
  controls?: 'split' | 'grouped';
}

const {
  ariaLabel,
  slideCount,
  counter = false,
  controls = 'split',
  class: className,
  ...attrs
} = Astro.props;
// ‹ X / N › is meaningless without N, so the grouped cluster always shows the counter.
const showCounter = counter || controls === 'grouped';
---

<section
  class:list={['fc', { 'fc--grouped': controls === 'grouped' }, className]}
  aria-roledescription="carrousel"
  aria-label={ariaLabel}
  data-fc
  {...attrs}
>
  <div class="fc__track" data-fc-track>
    <slot />
  </div>

  {
    /* Absolutely-positioned overlays (project card, pills, info/related bands) live here, inside the
      positioned .fc but outside the track, so they never become slides (`track.children`). */
  }
  <slot name="overlays" />

  {
    /* Wrapper is `display:contents` in split mode (children keep their own absolute anchoring) and a
      flex row bottom-right in grouped mode. Visual order prev → counter → next drives the cluster. */
  }
  {
    /* Rendered visible at all times (never popped in). Both arrows start `disabled` (dimmed) so the
      carousel shows a loading state; the script enables/updates them per slide position once ready.
      With no JS they simply stay disabled while the native scroll-snap swipe still works. */
  }
  <div class="fc__controls">
    <button
      type="button"
      class="fc__arrow fc__arrow--prev"
      data-fc-prev
      aria-label="Diapositive précédente"
      disabled
    >
      <Chevron direction="left" size={40} />
    </button>
    {
      showCounter && (
        <p class="fc__counter" data-fc-counter aria-hidden="true">
          <span data-fc-current>1</span> / {slideCount}
        </p>
      )
    }
    <button
      type="button"
      class="fc__arrow fc__arrow--next"
      data-fc-next
      aria-label="Diapositive suivante"
      disabled
    >
      <Chevron direction="right" size={40} />
    </button>
  </div>

  {/* Slide changes announced here; the visual counter stays aria-hidden to avoid double-speak. */}
  <p class="visually-hidden" data-fc-live aria-live="polite" role="status"></p>
</section>

<script>
  import '../scripts/fullscreen-carousel';
</script>

<style>
  .fc {
    position: relative;
    height: 100%;
    overflow: hidden;
    /* Ink for controls/HUD text sitting directly over the photo. Flipped per active slide's
       titre_clair by the script (`[data-clair]`); overlays with their own background ignore it. */
    --hud-ink: var(--color-coral);
  }
  .fc[data-clair] {
    --hud-ink: var(--color-paper);
  }

  .fc__track {
    display: flex;
    height: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .fc__track::-webkit-scrollbar {
    display: none;
  }

  /* Generic slide sizing — turns ANY slot child into a full-viewport snap slide. */
  .fc__track > :global(*) {
    flex: 0 0 100%;
    height: 100%;
    margin: 0;
    scroll-snap-align: start;
  }
  .fc__track > :global(*) :global(img),
  .fc__track > :global(*) :global(video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Split mode (home): the wrapper is transparent, so its children keep the absolute anchoring
     below (mid-height arrows + bottom-right counter), pixel-identical to before the wrapper existed. */
  .fc__controls {
    display: contents;
  }

  /* Controls are absolute overlays shown at ALL times (the arrows ship `disabled`/dimmed and the
     script enables them once ready), so they never pop in after load. Absolute → zero CLS. */
  .fc__counter {
    display: block;
  }
  .fc__arrow {
    display: grid;
    position: absolute;
    top: 50%;
    z-index: 2;
    transform: translateY(-50%);
    place-items: center;
    min-width: 44px;
    min-height: 44px;
    padding: var(--space-2);
    border: 0;
    background: none;
    color: var(--accent);
    cursor: pointer;
    filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.35));
    touch-action: manipulation;
  }
  .fc__arrow--prev {
    left: var(--space-2);
  }
  .fc__arrow--next {
    right: var(--space-2);
  }
  .fc__arrow:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .fc__counter {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: 2;
    margin: 0;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.35));
  }

  /* Grouped mode (project page): prev → counter → next as one bottom-right ‹ X / N › cluster.
     The wrapper becomes the positioned box; its children flow inline. Ink flips per active slide
     (--hud-ink); the drop-shadow keeps it legible over any photo. */
  .fc--grouped .fc__controls {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }
  .fc--grouped .fc__arrow,
  .fc--grouped .fc__counter {
    position: static;
    inset: auto;
    transform: none;
    color: var(--hud-ink);
  }
  /* Compact cluster: thin chevrons hugging the "X / N", 44px-tall touch target, tight horizontally. */
  .fc--grouped .fc__arrow {
    min-width: 0;
    min-height: 2.75rem;
    padding: 0 var(--space-1);
  }
  .fc--grouped .fc__counter {
    font-size: 1.25rem;
    letter-spacing: 0.02em;
  }
  .fc--grouped .fc__arrow :global(svg) {
    width: 1.25rem;
    height: 1.25rem;
    stroke-width: 1.5px;
  }
</style>
