---
import SocialLinks from './SocialLinks.astro';
import { telHref } from '../lib/url';
import type { GlobalSettings } from '../types/storyblok';

interface Props {
  settings: GlobalSettings | null;
  activeSection: 'projets' | 'atelier' | null;
}

const { settings, activeSection } = Astro.props;
const social = settings?.reseaux_sociaux ?? [];
const tel = telHref(settings?.telephone);
---

<div class="mobile-nav">
  {/* Visually-hidden but focusable: the no-JS open/close control (label toggles it). */}
  <input
    class="mobile-nav__checkbox visually-hidden"
    type="checkbox"
    id="mobile-nav-toggle"
    aria-label="Menu"
    aria-controls="mobile-panel"
  />
  <label class="mobile-nav__burger" for="mobile-nav-toggle">
    <span class="mobile-nav__burger-bars" aria-hidden="true"></span>
    <span class="visually-hidden">Ouvrir le menu</span>
  </label>

  {/* Scrim closes on click via the enhancement script; the in-panel ✕ is the no-JS close. */}
  <div class="mobile-nav__scrim" aria-hidden="true"></div>

  <div
    class="mobile-nav__panel"
    id="mobile-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Menu"
  >
    <div class="mobile-nav__panel-head">
      <span class="mobile-nav__title">{settings?.nom_atelier ?? 'LaMinga'}</span>
      <label class="mobile-nav__close" for="mobile-nav-toggle">
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" focusable="false">
          <path
            d="M6 6l12 12M18 6L6 18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
        <span class="visually-hidden">Fermer le menu</span>
      </label>
    </div>

    <nav class="mobile-nav__links" aria-label="Navigation">
      <a href="/atelier" aria-current={activeSection === 'atelier' ? 'page' : undefined}>Atelier</a>
      <a href="/projets" aria-current={activeSection === 'projets' ? 'page' : undefined}>Projets</a>
    </nav>

    <div class="mobile-nav__contact">
      {settings?.email && <a href={`mailto:${settings.email}`}>{settings.email}</a>}
      {tel && <a href={tel}>{settings?.telephone}</a>}
      {settings?.adresse_paris && <address class="pre-line">{settings.adresse_paris}</address>}
      {settings?.adresse_anglet && <address class="pre-line">{settings.adresse_anglet}</address>}
      <a class="mobile-nav__mentions" href="/mentions-legales">Mentions légales</a>
    </div>

    <SocialLinks links={social} class="mobile-nav__social" />
  </div>
</div>

<style>
  .mobile-nav {
    display: inline-flex;
  }

  /* Burger button (the label drives the hidden checkbox — works with no JS). */
  .mobile-nav__burger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: var(--border-w) solid var(--accent);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--color-paper) 85%, transparent);
    cursor: pointer;
  }
  .mobile-nav__burger-bars,
  .mobile-nav__burger-bars::before,
  .mobile-nav__burger-bars::after {
    content: '';
    display: block;
    width: 1.25rem;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }
  .mobile-nav__burger-bars {
    position: relative;
  }
  .mobile-nav__burger-bars::before {
    position: absolute;
    top: -6px;
  }
  .mobile-nav__burger-bars::after {
    position: absolute;
    top: 6px;
  }
  /* Visible focus ring on the burger when the (hidden) checkbox is focused. */
  .mobile-nav__checkbox:focus-visible + .mobile-nav__burger {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Scrim + panel — fixed, so they escape the header box. */
  .mobile-nav__scrim {
    position: fixed;
    inset: 0;
    z-index: var(--z-scrim);
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--transition),
      visibility var(--transition);
    cursor: pointer;
  }
  .mobile-nav__panel {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: var(--z-panel);
    width: min(86vw, 22rem);
    padding: var(--space-6) var(--space-5) calc(var(--space-6) + env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    background: var(--color-paper);
    border-right: var(--border);
    overflow-y: auto;
    transform: translateX(-100%);
    /* Hidden when closed so its links leave the tab order (no-JS safe); the delayed
       visibility keeps the panel on screen while it slides out. */
    visibility: hidden;
    transition:
      transform var(--transition),
      visibility 0s linear 200ms;
  }

  .mobile-nav__checkbox:checked ~ .mobile-nav__scrim {
    opacity: 1;
    visibility: visible;
  }
  .mobile-nav__checkbox:checked ~ .mobile-nav__panel {
    transform: translateX(0);
    visibility: visible;
    transition:
      transform var(--transition),
      visibility 0s;
  }

  .mobile-nav__panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mobile-nav__title {
    font-weight: 700;
    color: var(--accent);
  }
  .mobile-nav__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    margin: calc(-1 * var(--space-2)) calc(-1 * var(--space-2)) 0 0;
    color: var(--accent);
    cursor: pointer;
  }

  .mobile-nav__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .mobile-nav__links a {
    display: block;
    padding: var(--space-3);
    border: var(--border-w) solid var(--accent);
    border-radius: var(--radius);
    color: var(--accent);
    font-size: 1.0625rem;
    text-decoration: none;
  }
  .mobile-nav__links a[aria-current='page'] {
    background: var(--color-beige);
    color: var(--color-ink);
    font-weight: 600;
  }

  .mobile-nav__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-size: 0.9375rem;
  }
  .mobile-nav__contact a {
    color: var(--color-ink);
    text-decoration: none;
  }
  .mobile-nav__contact a:hover {
    text-decoration: underline;
  }
  .mobile-nav__contact address {
    margin: 0;
    font-style: normal;
    color: color-mix(in srgb, var(--color-ink) 75%, var(--color-paper));
  }
  .mobile-nav__mentions {
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--accent) !important;
  }

  /* Desktop: no burger/panel — the stacked buttons + social take over. */
  @media (min-width: 48rem) {
    .mobile-nav {
      display: none;
    }
  }
</style>

<script>
  import '../scripts/mobile-panel';
</script>
