---
import SocialLinks from './SocialLinks.astro';
import type { GlobalSettings } from '../types/storyblok';

interface Props {
  settings: GlobalSettings | null;
}

const { settings } = Astro.props;
const social = settings?.reseaux_sociaux ?? [];
const nomAtelier = settings?.nom_atelier ?? 'LaMinga';
// SVG logo rendered from the raw filename (the image service would rasterize it).
const logo = settings?.logo?.filename;
---

<header class="site-header">
  <nav class="nav" aria-label="Navigation principale">
    <a href="/" class="nav__logo">
      {logo ? <img src={logo} alt={nomAtelier} height="32" /> : nomAtelier}
    </a>
    <ul class="nav__links">
      <li><a href="/projets">Projets</a></li>
      <li><a href="/atelier">Atelier</a></li>
    </ul>
    <SocialLinks links={social} class="nav__social" />
  </nav>
</header>
