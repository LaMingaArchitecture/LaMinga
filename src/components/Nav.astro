---
import SocialLinks from './SocialLinks.astro';
import MobilePanel from './MobilePanel.astro';
import type { GlobalSettings } from '../types/storyblok';

interface Props {
  settings: GlobalSettings | null;
  /** Page accent: 'coral' on the immersive home (repo corail logo), 'violet' elsewhere. */
  accent?: 'coral' | 'violet';
}

const { settings, accent = 'violet' } = Astro.props;
const social = settings?.reseaux_sociaux ?? [];
const nomAtelier = settings?.nom_atelier ?? 'LaMinga';
// Logo per the charte: the corail variant ships in the repo for the immersive home header; the
// violet variant is editor-managed in Storyblok (global_settings.logo), with a repo violet
// fallback (also for an empty/whitespace Storyblok value — `??` alone won't catch `''`). Rendered
// from the raw filename/path (the image service would rasterize the SVG).
const storyblokLogo = settings?.logo?.filename?.trim();
const logo =
  accent === 'coral' ? '/logo/logo-corail.svg' : storyblokLogo || '/logo/logo-violet.svg';

// Active section from the current path — a project detail belongs to the Projets section.
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const activeSection: 'projets' | 'atelier' | null =
  path === '/projets' || path.startsWith('/projets/')
    ? 'projets'
    : path === '/atelier'
      ? 'atelier'
      : null;
---

<header class="site-header">
  <nav class="nav" aria-label="Navigation principale">
    <div class="nav__left">
      <MobilePanel settings={settings} activeSection={activeSection} />
      <ul class="nav__buttons">
        <li>
          <a
            class="nav__btn brand-box"
            href="/atelier"
            aria-current={activeSection === 'atelier' ? 'page' : undefined}
          >
            Atelier
          </a>
        </li>
        <li>
          <a
            class="nav__btn brand-box"
            href="/projets"
            aria-current={activeSection === 'projets' ? 'page' : undefined}
          >
            Projets
          </a>
        </li>
      </ul>
    </div>

    <a href="/" class="nav__logo" aria-label={`${nomAtelier} — accueil`}>
      <img class="nav__logo-img" src={logo} alt={nomAtelier} />
    </a>

    <div class="nav__right">
      <SocialLinks links={social} class="nav__social" />
    </div>
  </nav>
</header>

<style>
  .nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    min-height: var(--header-h-mobile);
    padding: var(--space-2) var(--space-4);
  }

  /* Logo — centered, links home. The official SVG already carries the boxed-outline mark, so the
     wrapper stays borderless (no double box). */
  .nav__logo {
    grid-column: 2;
    justify-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    line-height: 1;
  }
  .nav__logo-img {
    height: 2.25rem;
    width: auto;
  }

  /* Left = burger (mobile) / stacked buttons (desktop); right = social (desktop). */
  .nav__left {
    grid-column: 1;
    justify-self: start;
  }
  .nav__right {
    grid-column: 3;
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  /* Header social row: desktop only (the burger panel carries social on mobile). */
  .nav__right :global(.nav__social) {
    display: none;
  }

  /* Stacked outlined nav buttons — hidden on mobile (the burger takes over). */
  .nav__buttons {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-direction: column;
    gap: var(--space-2);
  }
  /* Box outline comes from the .brand-box utility (open-corner edges). Set background-color (not the
     background shorthand) so hover/active fills don't wipe the edge gradients. */
  .nav__btn {
    display: block;
    min-width: 7.5rem;
    padding: var(--space-1) var(--space-3);
    color: var(--accent);
    font-size: 0.9375rem;
    text-decoration: none;
    text-align: left;
    /* The fill swaps via --brand-box-fill (a gradient layer), which can't transition; only the text
       colour animates. */
    transition: color var(--transition);
  }
  .nav__btn:hover {
    --brand-box-fill: color-mix(in srgb, var(--color-beige) 45%, var(--color-paper));
  }
  .nav__btn[aria-current='page'] {
    --brand-box-fill: var(--color-beige);
    color: var(--color-ink);
    font-weight: 600;
  }

  /* Desktop: reveal the three-zone header. */
  @media (min-width: 48rem) {
    .nav {
      min-height: var(--header-h);
      padding: var(--space-3) var(--space-6);
      align-items: start;
    }
    .nav__buttons {
      display: flex;
    }
    .nav__btn {
      min-width: 9rem;
      padding: var(--space-2) var(--space-4);
      font-size: 1.125rem;
    }
    .nav__right :global(.nav__social) {
      display: flex;
    }
    .nav__logo {
      align-self: start;
    }
    .nav__logo-img {
      height: 3.5rem;
    }
  }
</style>
