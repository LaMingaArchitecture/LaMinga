---
import ProjectVignettes from './ProjectVignettes.astro';
import ProjectIndexTable from './ProjectIndexTable.astro';
import type { ProgrammeLink, ProjectSummary, ThematiqueEntry } from '../types/storyblok';

interface Props {
  projects: ProjectSummary[];
  programmes: ProgrammeLink[];
  thematiques: ThematiqueEntry[];
}

const { projects, programmes, thematiques } = Astro.props;

// Only surface programmes / thematiques actually used by published projects.
const usedProgrammes = new Set(projects.map((p) => p.programme?.slug).filter(Boolean));
const usedThematiques = new Set(projects.flatMap((p) => p.thematiques));
const programmeFilters = programmes.filter((p) => usedProgrammes.has(p.slug));
const thematiqueFilters = thematiques.filter((t) => usedThematiques.has(t.value));

// Which programmes each thematique appears in → the script uses this to keep row 2 limited to the
// thematiques present in the selected programme's projects (all in-use thematiques when none).
const thematiqueProgrammes = new Map<string, Set<string>>();
for (const project of projects) {
  const slug = project.programme?.slug;
  if (!slug) continue;
  for (const value of project.thematiques) {
    let set = thematiqueProgrammes.get(value);
    if (!set) {
      set = new Set<string>();
      thematiqueProgrammes.set(value, set);
    }
    set.add(slug);
  }
}
const programmesForThematique = (value: string) =>
  [...(thematiqueProgrammes.get(value) ?? [])].join(' ');
---

<div class="explorer" data-explorer>
  <div class="explorer__sticky">
    <div class="explorer__filters">
      {
        programmeFilters.length > 0 && (
          <div class="explorer__row" role="group" aria-label="Filtrer par programme">
            {/* data-programme-filter drives the JS filter; data-programme receives the
                --programme-color / --programme-ink vars from BaseLayout's global colour map. */}
            {programmeFilters.map((programme) => (
              <button
                type="button"
                class="explorer__chip explorer__chip--programme brand-box"
                data-programme-filter={programme.slug}
                data-programme={programme.slug}
                aria-pressed="false"
              >
                {programme.nom}
              </button>
            ))}
          </div>
        )
      }
      {
        thematiqueFilters.length > 0 && (
          <div class="explorer__row" role="group" aria-label="Filtrer par thématique">
            {thematiqueFilters.map((thematique) => (
              <button
                type="button"
                class="explorer__chip explorer__chip--thematique brand-box"
                data-thematique-filter={thematique.value}
                data-thematique-programmes={programmesForThematique(thematique.value)}
                aria-pressed="false"
              >
                {thematique.name}
              </button>
            ))}
          </div>
        )
      }
    </div>

    <div class="explorer__tools" role="group" aria-label="Affichage et recherche">
      <button type="button" class="explorer__tool" data-view-vignettes aria-pressed="true">
        Affichage Vignettes
      </button>
      <button type="button" class="explorer__tool" data-view-index aria-pressed="false">
        Affichage Liste
      </button>
      <button
        type="button"
        class="explorer__tool"
        data-search-toggle
        aria-expanded="false"
        aria-controls="projets-recherche"
      >
        Recherche
      </button>
      <input
        type="search"
        id="projets-recherche"
        class="explorer__search brand-box"
        data-search-input
        placeholder="Rechercher un projet…"
        aria-label="Rechercher un projet"
        hidden
      />
    </div>
  </div>

  <div class="explorer__views">
    <p class="explorer__empty" data-empty hidden>Aucun projet ne correspond à ces filtres.</p>
    <ProjectVignettes projects={projects} />
    <ProjectIndexTable projects={projects} />
  </div>
</div>

<style>
  .explorer {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Filters + tool row stay visible while the views scroll with the page. */
  .explorer__sticky {
    position: sticky;
    top: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block: var(--space-2);
    background: var(--color-beige-10);
  }
  /* Mobile: the whole document scrolls (footer flows away), so the filters anchor to the page and
     must clear the pinned header instead of sticking at the very top. */
  @media (max-width: 47.999rem) {
    .explorer__sticky {
      top: var(--header-h-mobile);
    }
  }
  .explorer__filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .explorer__row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Chips use the .brand-box open-corner outline (same architectural look as the Liste table cells
     + nav buttons). State is driven by --brand-box-line (outline) and --brand-box-fill (selected
     fill) — never a `background`/`border` shorthand, which would wipe the edge gradients. */
  .explorer__chip {
    flex: 1 1 9rem;
    min-width: 8rem;
    max-width: 14rem;
    min-height: 2.75rem; /* ≥44px touch target */
    padding: var(--space-2) var(--space-3);
    /* Reset the native <button> chrome (a 2px outset border + appearance) so ONLY the .brand-box
       open-corner gradients show — otherwise the default border paints over the corner gaps. */
    appearance: none;
    -webkit-appearance: none;
    border: 0;
    color: var(--accent);
    font-size: 0.875rem;
    text-align: left;
    cursor: pointer;
    transition: color var(--transition);
  }
  .explorer__chip:hover {
    --brand-box-line: var(--accent);
  }
  .explorer__chip[hidden] {
    display: none;
  }

  /* Programme chips (row 1) carry their Storyblok colour on the outline; selected = filled + ink. */
  .explorer__chip--programme {
    --brand-box-line: var(--programme-color, var(--color-line));
  }
  .explorer__chip--programme[aria-pressed='true'] {
    --brand-box-line: var(--programme-color, var(--accent));
    --brand-box-fill: var(--programme-color, var(--accent));
    color: var(--programme-ink, var(--color-paper));
    font-weight: 600;
  }

  /* Thematique chips (row 2) are serif italic; selected = beige tint fill. */
  .explorer__chip--thematique {
    --brand-box-line: var(--color-line);
    font-family: var(--font-serif);
    font-style: italic;
  }
  .explorer__chip--thematique[aria-pressed='true'] {
    --brand-box-line: var(--accent);
    --brand-box-fill: var(--color-beige);
    color: var(--color-ink);
    font-weight: 600;
  }

  /* Tool row — plain serif-italic text links; active view / open search = corail upright. Reserve
     the search field's height at all times (align-items:center keeps the links centred) so revealing
     the input never grows the row / sticky bar and shifts the grid ("clipping" jump). */
  .explorer__tools {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    min-height: 2.75rem;
  }
  .explorer__tool {
    border: 0;
    background: none;
    padding: var(--space-1) 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--accent);
    cursor: pointer;
  }
  .explorer__tool[aria-pressed='true'],
  .explorer__tool[aria-expanded='true'] {
    color: var(--color-coral);
    font-style: normal;
  }
  /* Search field shares the .brand-box open-corner outline (like the filter chips + nav buttons).
     Reset the native <input> chrome so only the brand-box gradients show. The open-corner edge is
     the focus affordance here: grey (--color-line) at rest → aubergine (--accent) on focus, and the
     default focus ring is suppressed so the colour change alone signals focus (per design). */
  .explorer__search {
    --brand-box-line: var(--color-line);
    appearance: none;
    -webkit-appearance: none;
    border: 0;
    min-height: 2.75rem;
    padding: var(--space-2) var(--space-3);
    color: var(--color-ink);
    font-size: 0.875rem;
    min-width: 12rem;
    transition: none;
  }
  .explorer__search::placeholder {
    color: var(--color-muted);
  }
  .explorer__search:focus,
  .explorer__search:focus-visible {
    --brand-box-line: var(--accent);
    outline: none;
  }
  .explorer__search[hidden] {
    display: none;
  }

  .explorer__views {
    min-height: 0;
  }
  .explorer__empty {
    margin: var(--space-6) 0;
    color: var(--color-muted);
  }
  .explorer__empty[hidden] {
    display: none;
  }

  /* When a programme filter is active, the visible (matching) vignettes take its colour on the
     square border + caption — each tile supplies its own --programme-color via its data-programme. */
  .explorer[data-programme-active] :global(.project-card--vignette .project-card__cover) {
    border-color: var(--programme-color, var(--accent));
  }
  .explorer[data-programme-active] :global(.project-card--vignette .project-card__title) {
    color: var(--programme-color, var(--accent));
  }
</style>

<script>
  import '../scripts/projets-explorer';
</script>
