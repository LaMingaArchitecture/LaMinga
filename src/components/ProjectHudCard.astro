---
/**
 * ProjectHudCard — the persistent bleu-clair project card pinned to the bottom HUD on every slide.
 * Mini-table: a title cell (the page's sole <h1>) beside "Ville" / "Programme" rows. Positioning is
 * owned by the .project-hud bar in Project.astro; this component owns only the card's appearance.
 * "Programme" = description_programme (the one-line description), not the programme relation.
 */
interface Props {
  titre: string;
  ville?: string;
  programme?: string;
}

const { titre, ville, programme } = Astro.props;
---

<div class="hud-card">
  <h1 class="hud-card__title">{titre}</h1>
  {
    (ville || programme) && (
      <dl class="hud-card__data">
        {ville && (
          <div class="hud-card__row">
            <dt>Ville</dt>
            <dd>{ville}</dd>
          </div>
        )}
        {programme && (
          <div class="hud-card__row">
            <dt>Programme</dt>
            <dd class="hud-card__desc">{programme}</dd>
          </div>
        )}
      </dl>
    )
  }
</div>

<style>
  /* Deep navy card so the coral title/values clear WCAG AA (light bleu-clair failed on corail);
     labels flip to paper (--panel-ink), hairlines to --panel-line. See tokens.css. */
  .hud-card {
    pointer-events: auto;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    max-width: min(92vw, 34rem);
    background: var(--panel-bg);
    border: var(--border-w) solid var(--panel-line);
    border-radius: var(--radius);
  }
  .hud-card__title {
    align-self: stretch;
    display: flex;
    align-items: center;
    margin: 0;
    padding: var(--space-3) var(--space-4);
    border-right: var(--border-w) solid var(--panel-line);
    color: var(--color-coral);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.25rem;
  }
  .hud-card__data {
    margin: 0;
    display: grid;
  }
  /* Narrower label column than before so the value keeps enough room to wrap on word boundaries on
     mobile (avoids mid-word clamps like "Restru… / de…"). min-content floor lets the widest label
     ("Programme" in the wide didone italic) size itself so it never clips, capped at 5.5rem. */
  .hud-card__row {
    display: grid;
    grid-template-columns: minmax(min-content, 5.5rem) minmax(0, 1fr);
    gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-2) var(--space-4);
  }
  .hud-card__row + .hud-card__row {
    border-top: var(--border-w) solid var(--panel-line);
  }
  .hud-card__row dt {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--panel-ink);
  }
  .hud-card__row dd {
    margin: 0;
    color: var(--color-coral);
    font-size: 0.9375rem;
  }
  /* The programme description can be long — cap it to two lines on the compact card. */
  .hud-card__desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
