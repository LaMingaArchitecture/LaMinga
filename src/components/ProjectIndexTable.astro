---
import { sbImage } from '../lib/image';
import { projectSearchText } from '../lib/search';
import type { ProjectSummary } from '../types/storyblok';

interface Props {
  projects: ProjectSummary[];
}

const { projects } = Astro.props;
---

{
  /* Liste (index) view: boxed-cell table. Rows carry the same filter hooks as the vignettes; hover
    tints the row corail and the script floats the project's cover thumbnail. Scrolls with the page
    (sticky filters keep the rows filterable). */
}
<div class="index" data-view="index" hidden>
  <div class="index__scroll">
    <div class="index__table-wrap">
      <table class="index-table">
        <thead>
          <tr>
            <th scope="col" class="brand-box">Nom du projet</th>
            <th scope="col" class="brand-box">Maîtrise d'ouvrage</th>
            <th scope="col" class="brand-box">Lieu</th>
            <th scope="col" class="brand-box">Programme</th>
            <th scope="col" class="brand-box">Statut</th>
            <th scope="col" class="brand-box"
              ><span class="visually-hidden">Lien vers le projet</span></th
            >
          </tr>
        </thead>
        <tbody>
          {
            projects.map((project) => (
              <tr
                data-filterable
                data-programme={project.programme?.slug ?? ''}
                data-thematiques={project.thematiques.join(' ')}
                data-search={projectSearchText(project)}
                data-thumb={project.photo?.filename ? sbImage(project.photo.filename, '400x0') : ''}
              >
                <th scope="row" class="index__name brand-box">
                  <a href={`/projets/${project.slug}`}>{project.titre}</a>
                </th>
                <td class="brand-box">{project.maitre_ouvrage}</td>
                <td class="brand-box">{project.ville}</td>
                <td class="brand-box">{project.description_programme}</td>
                <td class="brand-box">{project.statut}</td>
                <td class="index__link brand-box">
                  <a href={`/projets/${project.slug}`}>Voir le projet</a>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    {
      /* Shared floating preview — positioned + fed by the script on row hover (one request per row). */
    }
    <img class="index__thumb" data-thumb-el alt="" hidden />
  </div>
</div>

<style>
  .index {
    min-height: 0;
  }
  .index[hidden] {
    display: none;
  }
  .index__scroll {
    position: relative;
  }
  /* Contain the wide table's horizontal scroll here (not the page) so the sticky filters stay put. */
  .index__table-wrap {
    overflow-x: auto;
    overscroll-behavior-x: contain;
  }

  .index-table {
    width: 100%;
    min-width: 44rem;
    border-collapse: separate;
    border-spacing: var(--space-2);
    font-size: 0.875rem;
  }
  /* Cell outline + paper fill come from the .brand-box utility (open-corner edges). */
  .index-table th,
  .index-table td {
    text-align: left;
    padding: var(--space-2) var(--space-3);
    vertical-align: middle;
  }
  .index-table thead th {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--color-muted);
    white-space: nowrap;
  }
  .index-table td,
  .index-table .index__link {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-ink);
  }
  .index-table tbody th {
    font-weight: 600;
    color: var(--color-ink);
  }
  .index-table a {
    color: inherit;
    text-decoration: none;
  }
  .index__link {
    white-space: nowrap;
  }
  .index-table tr[hidden] {
    display: none;
  }

  /* Hover: tint the row corail (title included); the violet double-stroke stays. */
  .index-table tbody tr:hover th,
  .index-table tbody tr:hover td {
    color: var(--color-coral);
  }
  .index-table tbody th a:hover,
  .index__link a:hover {
    text-decoration: underline;
  }

  .index__thumb {
    position: absolute;
    left: 20%;
    width: clamp(9rem, 22vw, 14rem);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: var(--border-w) solid var(--color-coral);
    border-radius: var(--radius);
    box-shadow: 0 12px 30px -16px color-mix(in srgb, var(--color-ink) 60%, transparent);
    pointer-events: none;
    z-index: 3;
  }
  .index__thumb[hidden] {
    display: none;
  }

  /* No hover preview on touch/coarse pointers. */
  @media (hover: none) {
    .index__thumb {
      display: none !important;
    }
  }
</style>
