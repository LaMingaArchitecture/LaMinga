---
/**
 * ProjectRecapSlide — the carousel's final slide: a mosaic of every visual. Each thumbnail is a
 * button carrying `data-fc-goto={i}`; the carousel script jumps to slide i on click. Video-only
 * slides fall back to their poster, else a neutral placeholder. Rendered as a normal track child
 * (full-viewport), padded to clear the floating header and the bottom HUD.
 */
import { sbImage } from '../lib/image';
import type { MediaSlideBlok } from '../types/storyblok';

interface Props {
  slides: MediaSlideBlok[];
}

const { slides } = Astro.props;

const thumbSrc = (slide: MediaSlideBlok): string => {
  const source =
    slide.image_paysage?.filename ?? slide.image_portrait?.filename ?? slide.poster?.filename;
  return source ? sbImage(source, '400x400') : '';
};
---

<div class="recap">
  <ul class="recap__grid">
    {
      slides.map((slide, index) => {
        const src = thumbSrc(slide);
        return (
          <li>
            <button
              type="button"
              class="recap__item"
              data-fc-goto={index}
              aria-label={`Aller à la diapositive ${index + 1}`}
            >
              {src ? (
                <img src={src} alt="" loading="lazy" />
              ) : (
                <span class="recap__placeholder" aria-hidden="true" />
              )}
            </button>
          </li>
        );
      })
    }
  </ul>
</div>

<style>
  .recap {
    height: 100%;
    display: grid;
    place-items: center;
    padding: calc(var(--header-h-mobile) + var(--space-4)) var(--space-4) 8rem;
    background: var(--color-paper);
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .recap__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 60rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(7rem, 1fr));
    gap: var(--space-3);
  }
  .recap__item {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    padding: 0;
    border: var(--border-w) solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-paper);
    overflow: hidden;
    cursor: pointer;
    touch-action: manipulation;
    transition: transform var(--transition);
  }
  .recap__item:hover {
    transform: translateY(-2px);
  }
  .recap__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--color-beige-10);
  }

  @media (min-width: 48rem) {
    .recap {
      padding: calc(var(--header-h) + var(--space-4)) var(--space-6) 7rem;
    }
  }
</style>
