---
import ProjectCard from './ProjectCard.astro';
import { projectSearchText } from '../lib/search';
import type { ProjectSummary } from '../types/storyblok';

interface Props {
  projects: ProjectSummary[];
}

const { projects } = Astro.props;
---

{
  /* Vignettes view: a row-major responsive grid of square plan-masse tiles that fills the first row
    across the width before wrapping (2 cols mobile → up to 5 on wide, capped so tiles stay a
    comfortable size). Filtering hides non-matching <li>s; the rest regroup left. */
}
<div class="vignettes" data-view="grid">
  <ul class="vignettes__rail">
    {
      projects.map((project) => (
        <li
          class="vignettes__item"
          data-filterable
          data-programme={project.programme?.slug ?? ''}
          data-thematiques={project.thematiques.join(' ')}
          data-search={projectSearchText(project)}
        >
          <ProjectCard project={project} variant="vignette" />
        </li>
      ))
    }
  </ul>
</div>

<style>
  .vignettes {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-height: 0;
  }
  .vignettes[hidden] {
    display: none;
  }

  .vignettes__rail {
    list-style: none;
    margin: 0;
    padding: 0 0 var(--space-2);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4) var(--space-3);
    /* Left-anchored, capped so tiles stay a comfortable size on ultra-wide screens instead of
       sprawling; the filters above are likewise left-aligned, so the page reads as one column. */
    max-width: 100rem;
  }
  @media (min-width: 40rem) {
    .vignettes__rail {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (min-width: 64rem) {
    .vignettes__rail {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  @media (min-width: 100rem) {
    .vignettes__rail {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }
  .vignettes__item {
    min-width: 0;
  }
  .vignettes__item[hidden] {
    display: none;
  }
</style>
