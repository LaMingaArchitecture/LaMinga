---
import { isHttpUrl } from '../lib/url';
import Instagram from './icons/Instagram.astro';
import LinkedIn from './icons/LinkedIn.astro';
import type { SocialLinkBlok } from '../types/storyblok';

interface Props {
  links: SocialLinkBlok[];
  class?: string;
  label?: string;
}

const { links, class: className, label = 'Réseaux sociaux' } = Astro.props;
// Normalize (trim) then keep only http(s) links, so the rendered href is exactly what was
// validated — leading/trailing whitespace can't slip into the anchor. Blocks javascript:/data:.
const safe = links
  .map((link) => ({ ...link, url: link.url?.trim() ?? '' }))
  .filter((link) => isHttpUrl(link.url));

// Detect the network so Instagram/LinkedIn render as the official inline marks. Inline (not <img>)
// lets them paint with currentColor = the page --accent, so they theme corail on the home header
// and violet elsewhere with no per-page asset swap. Any other network falls back to the Storyblok
// icon asset, then the platform name.
type Platform = 'instagram' | 'linkedin';
const DISPLAY_NAME: Record<Platform, string> = { instagram: 'Instagram', linkedin: 'LinkedIn' };
// Detect by URL host (anchored) rather than free-text substrings, so a label/URL merely containing
// "insta"/"lnkd" can't be mis-branded with the wrong official mark.
const platformOf = (url: string): Platform | null => {
  let host: string;
  try {
    host = new URL(url).hostname.toLowerCase();
  } catch {
    return null;
  }
  if (host === 'instagram.com' || host.endsWith('.instagram.com')) return 'instagram';
  if (host === 'linkedin.com' || host.endsWith('.linkedin.com') || host === 'lnkd.in') {
    return 'linkedin';
  }
  return null;
};
---

{
  safe.length > 0 && (
    <ul class:list={['social-links', className]} aria-label={label}>
      {safe.map((link) => {
        const platform = platformOf(link.url);
        // Always non-empty: trimmed editor label, else the detected network name, else a generic.
        const linkLabel =
          link.plateforme?.trim() || (platform ? DISPLAY_NAME[platform] : 'Réseau social');
        return (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={linkLabel}>
              {platform === 'instagram' ? (
                <Instagram />
              ) : platform === 'linkedin' ? (
                <LinkedIn />
              ) : link.icone?.filename ? (
                // Raw filename (the image service rasterizes SVG); decorative — the link is labelled.
                <img src={link.icone.filename} alt="" width="24" height="24" />
              ) : (
                // Text fallback: the computed label (never empty), consistent with aria-label.
                linkLabel
              )}
            </a>
          </li>
        );
      })}
    </ul>
  )
}

<style>
  .social-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 0.875rem;
    text-decoration: none;
  }
  .social-links :global(svg),
  .social-links img {
    width: 1.875rem;
    height: 1.875rem;
  }
</style>
