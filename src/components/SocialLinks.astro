---
import { isHttpUrl } from '../lib/url';
import type { SocialLinkBlok } from '../types/storyblok';

interface Props {
  links: SocialLinkBlok[];
  class?: string;
  label?: string;
}

const { links, class: className, label = 'Réseaux sociaux' } = Astro.props;
// Drop any link whose URL is not http(s) (blocks editor-supplied javascript:/data: hrefs).
const safe = links.filter((link) => isHttpUrl(link.url));
---

{
  safe.length > 0 && (
    <ul class:list={['social-links', className]} aria-label={label}>
      {safe.map((link) => (
        <li>
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            {link.icone?.filename ? (
              // SVG icon rendered from the raw filename (the image service rasterizes SVG).
              <img src={link.icone.filename} alt={link.plateforme} width="24" height="24" />
            ) : (
              link.plateforme
            )}
          </a>
        </li>
      ))}
    </ul>
  )
}
