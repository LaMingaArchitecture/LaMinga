---
import ProjectCard from './ProjectCard.astro';
import type { ProjectSummary, ThematiqueEntry } from '../types/storyblok';

interface Props {
  projects: ProjectSummary[];
  thematiques: ThematiqueEntry[];
}

const { projects, thematiques } = Astro.props;
---

<div class="thematique-filter">
  <div class="thematique-filter__controls" role="group" aria-label="Filtrer par thématique">
    <button type="button" data-filter="all" aria-pressed="true">Tous</button>
    {
      thematiques.map((thematique) => (
        <button type="button" data-filter={thematique.value} aria-pressed="false">
          {thematique.name}
        </button>
      ))
    }
  </div>
  <ul class="project-grid">
    {
      projects.map((project) => (
        <li data-thematiques={project.thematiques.join(' ')}>
          <ProjectCard project={project} />
        </li>
      ))
    }
  </ul>
</div>

<script>
  // Datasource-driven client filter: thematiques come from Storyblok, never hardcoded.
  // A project carries several thematiques, so match against its space-separated list.
  const root = document.querySelector<HTMLElement>('.thematique-filter');
  if (root) {
    const buttons = root.querySelectorAll<HTMLButtonElement>('button[data-filter]');
    const items = root.querySelectorAll<HTMLLIElement>('.project-grid > li');
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        buttons.forEach((other) => other.setAttribute('aria-pressed', String(other === button)));
        items.forEach((item) => {
          const values = item.dataset.thematiques?.split(' ') ?? [];
          item.hidden = filter !== 'all' && !values.includes(filter ?? '');
        });
      });
    });
  }
</script>
