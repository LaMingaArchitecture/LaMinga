---
import ProjectCard from './ProjectCard.astro';
import type { ProjectSummary, TypologieEntry } from '../types/storyblok';

interface Props {
  projects: ProjectSummary[];
  typologies: TypologieEntry[];
}

const { projects, typologies } = Astro.props;
---

<div class="typologie-filter">
  <div class="typologie-filter__controls" role="group" aria-label="Filtrer par typologie">
    <button type="button" data-filter="all" aria-pressed="true">Tous</button>
    {
      typologies.map((typologie) => (
        <button type="button" data-filter={typologie.value} aria-pressed="false">
          {typologie.name}
        </button>
      ))
    }
  </div>
  <ul class="project-grid">
    {
      projects.map((project) => (
        <li data-typologie={project.typologie}>
          <ProjectCard project={project} />
        </li>
      ))
    }
  </ul>
</div>

<script>
  // Datasource-driven client filter: typologies come from Storyblok, never hardcoded.
  const root = document.querySelector<HTMLElement>('.typologie-filter');
  if (root) {
    const buttons = root.querySelectorAll<HTMLButtonElement>('button[data-filter]');
    const items = root.querySelectorAll<HTMLLIElement>('.project-grid > li');
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        buttons.forEach((other) => other.setAttribute('aria-pressed', String(other === button)));
        items.forEach((item) => {
          item.hidden = filter !== 'all' && item.dataset.typologie !== filter;
        });
      });
    });
  }
</script>
