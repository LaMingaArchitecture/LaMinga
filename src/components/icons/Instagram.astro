---
/**
 * Instagram mark — monochrome outline on a TRANSPARENT background (per client feedback: no filled
 * badge/plate). Paints with `currentColor` (= the page --accent: corail on the home header, violet
 * elsewhere), so it themes with no per-page asset swap. Rendered inline (not <img>) so currentColor
 * resolves against the surrounding link colour.
 */
interface Props {
  size?: number | string;
  class?: string;
}
const { size = 24, class: className } = Astro.props;
---

<svg
  class:list={['icon', className]}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  <rect x="2" y="2" width="20" height="20" rx="5.5"></rect>
  <circle cx="12" cy="12" r="4.25"></circle>
  <circle cx="17.4" cy="6.6" r="1.15" fill="currentColor" stroke="none"></circle>
</svg>

<style>
  .icon {
    display: block;
  }
</style>
