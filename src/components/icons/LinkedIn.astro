---
/**
 * LinkedIn mark — monochrome "in" glyph on a TRANSPARENT background (per client feedback: no filled
 * badge/plate). Paints with `currentColor` (= the page --accent), so it themes corail on the home
 * header and violet elsewhere. Rendered inline (not <img>) so currentColor resolves against the link.
 */
interface Props {
  size?: number | string;
  class?: string;
}
const { size = 24, class: className } = Astro.props;
---

<svg
  class:list={['icon', className]}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="currentColor"
  aria-hidden="true"
  focusable="false"
>
  <path
    d="M6.94 5.5a1.94 1.94 0 1 1-3.88 0 1.94 1.94 0 0 1 3.88 0M3.32 8.98h3.24V21H3.32zM9.06 8.98h3.11v1.64h.04c.43-.82 1.49-1.69 3.07-1.69 3.28 0 3.89 2.16 3.89 4.97V21h-3.24v-5.44c0-1.3-.02-2.97-1.81-2.97s-2.09 1.41-2.09 2.87V21H9.06z"
  ></path>
</svg>

<style>
  .icon {
    display: block;
  }
</style>
