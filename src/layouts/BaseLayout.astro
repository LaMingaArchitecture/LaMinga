---
import '../styles/global.css';
import { PUBLIC_SITE_URL } from 'astro:env/client';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getSettings, getProgrammes, buildProgrammeColorCss } from '../lib/content';

interface Props {
  title?: string;
  description?: string;
  /** Set on placeholder pages so missing-content pages aren't indexed as live. */
  noindex?: boolean;
  /** Slim contact footer bar (Projets + Atelier + Mentions). Default false (immersive). */
  footer?: boolean;
  /** Let the page scroll instead of locking to the viewport (Atelier + Mentions). Default false. */
  scroll?: boolean;
  /** Accent theme: 'coral' on the immersive home, 'violet' everywhere else. */
  accent?: 'coral' | 'violet';
}

const {
  title = 'LaMinga',
  description = "Atelier d'architecture LaMinga.",
  noindex = false,
  footer = false,
  scroll = false,
  accent = 'violet',
} = Astro.props;

const settings = await getSettings();
// Programmes feed the site-wide programme→colour map below. getProgrammes is build-cached
// (published), so the whole SSG build makes a single call.
const programmes = await getProgrammes();

// Programme colours are applied via a global <style> keyed on [data-programme="<slug>"] rather
// than inline style="" attributes (which the strict hash-based CSP would block). This <style> is
// emitted in <head> BEFORE Astro's CSP <meta>, so it is not governed by the meta-CSP and always
// applies; buildProgrammeColorCss validates both interpolated values (slug whitelist + colorHex).
const programmeColorCss = buildProgrammeColorCss(programmes);

// The header floats over the hero on footer-less pages and sits as a solid bar otherwise.
const immersive = !footer;
const canonical = new URL(Astro.url.pathname, PUBLIC_SITE_URL).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {programmeColorCss && <style is:global set:html={programmeColorCss} />}
  </head>
  <body
    data-accent={accent}
    data-scroll={scroll ? '' : undefined}
    data-immersive={immersive ? '' : undefined}
  >
    <Nav settings={settings} accent={accent} />
    <main id="contenu">
      <slot />
    </main>
    {footer && <Footer settings={settings} />}
  </body>
</html>
