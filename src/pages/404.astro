---
import BaseLayout from '../layouts/BaseLayout.astro';

// Static (output:'static' → Astro emits /404.html; the Netlify adapter serves it for unmatched
// routes). noindex belt-and-suspenders on top of the 404 HTTP status.
---

<BaseLayout title="Page introuvable — LaMinga" noindex footer scroll>
  <section class="notfound">
    <p class="notfound__code" aria-hidden="true">404</p>
    <h1 class="notfound__title">Page introuvable</h1>
    <p class="notfound__text">La page que vous cherchez n'existe pas ou a été déplacée.</p>
    <nav class="notfound__actions" aria-label="Navigation de secours">
      <a class="notfound__link brand-box" href="/">Retour à l'accueil</a>
      <a class="notfound__link brand-box" href="/projets">Voir les projets</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .notfound {
    max-width: 40rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-4);
    min-height: 60svh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-4);
  }
  .notfound__code {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(3rem, 2rem + 8vw, 6rem);
    line-height: 1;
    color: var(--accent);
  }
  .notfound__title {
    margin: 0;
    color: var(--color-ink);
  }
  .notfound__text {
    margin: 0;
    color: var(--color-muted);
  }
  .notfound__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .notfound__link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-2) var(--space-4);
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    touch-action: manipulation;
  }
  .notfound__link:hover {
    --brand-box-fill: color-mix(in srgb, var(--accent) 10%, transparent);
  }
</style>
