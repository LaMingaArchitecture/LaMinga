---
export const prerender = false;

import type { SbBlokData } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import { STORYBLOK_VERSION } from 'astro:env/server';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getStoryblokApi } from '../../lib/storyblok';
import { PROJECT_RELATIONS, HOME_RELATIONS } from '../../lib/content';

// On-demand SSR route that renders DRAFT content live for the Storyblok Visual
// Editor. The guard keeps production effectively static: in the published
// environment this route returns 404 instead of serving drafts. The Visual
// Editor's preview URL points at /preview/ on the preview (SSR) deploy.
if (STORYBLOK_VERSION !== 'draft') {
  return new Response('Not found', { status: 404 });
}

const slug = Astro.params.slug ?? 'home';

async function fetchDraftContent(): Promise<SbBlokData | null> {
  try {
    const api = getStoryblokApi();
    const { data } = await api.get(`cdn/stories/${slug}`, {
      version: 'draft',
      resolve_relations: [...PROJECT_RELATIONS, ...HOME_RELATIONS],
    });
    return (data?.story?.content ?? null) as SbBlokData | null;
  } catch {
    return null;
  }
}

const content = await fetchDraftContent();

if (!content) {
  return new Response(`Aperçu introuvable : ${slug}`, { status: 404 });
}

// Mirror each page's production chrome so the Visual Editor preview matches the live page. The
// Atelier needs its immersive fullscreen-scroll frame (footer + overlaid header + immersiveScroll);
// every other story keeps the plain scrolling document.
const isAtelier = content.component === 'atelier_page';
---

<BaseLayout
  title="Aperçu — LaMinga"
  scroll={!isAtelier}
  footer={isAtelier}
  immersive={isAtelier}
  immersiveScroll={isAtelier}
>
  <StoryblokComponent blok={content} />
</BaseLayout>
