---
import type { GetStaticPaths } from 'astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllProjects } from '../../lib/content';
import type { ProjectBlok } from '../../types/storyblok';

export const getStaticPaths = (async () => {
  const projects = await getAllProjects();
  return projects.map(({ slug, blok }) => ({ params: { slug }, props: { blok } }));
}) satisfies GetStaticPaths;

const { blok } = Astro.props as { blok: ProjectBlok };
// Meaningful title + meta derived from the project (titre + ville), per the design spec.
const title = `${blok.titre}${blok.ville ? ` — ${blok.ville}` : ''} — LaMinga`;
const description =
  blok.description_programme ??
  `${blok.titre}${blok.ville ? `, ${blok.ville}` : ''} — projet de l'atelier d'architecture LaMinga.`;
---

<BaseLayout title={title} description={description}>
  <StoryblokComponent blok={blok} />
</BaseLayout>
