---
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentNotice from '../../components/ContentNotice.astro';
import { getProjectListPage } from '../../lib/content';
import { resolveSeo, firstSeo, richTextToPlain } from '../../lib/seo';

const blok = await getProjectListPage();
const resolved = resolveSeo({
  seo: firstSeo(blok?.seo),
  title: 'Projets — LaMinga',
  description: richTextToPlain(blok?.intro),
});
---

<BaseLayout
  title={resolved.title}
  description={resolved.description}
  ogImage={resolved.ogImage}
  footer
  noindex={!blok}
>
  {blok ? <StoryblokComponent blok={blok} /> : <ContentNotice />}
</BaseLayout>
