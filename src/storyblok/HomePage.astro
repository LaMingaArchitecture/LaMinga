---
import { storyblokEditable } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import type { HomePageBlok } from '../types/storyblok';

const { blok } = Astro.props as { blok: HomePageBlok };
// Ordered homepage slides (each links to a project and derives its title from it).
// Rendered in document order here; the fullscreen-carousel interaction is a separate concern.
const slides = blok.carrousel ?? [];
---

<div class="home" {...storyblokEditable(blok)}>
  {slides.map((slide) => <StoryblokComponent blok={slide} />)}
</div>

<!-- Baseline: fullscreen horizontal scroll-snap carousel. The richer carousel
     interaction (arrows, autoplay) is the home-page ticket's concern. -->
<style>
  .home {
    display: flex;
    height: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .home::-webkit-scrollbar {
    display: none;
  }
</style>
