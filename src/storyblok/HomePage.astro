---
import { storyblokEditable } from '@storyblok/astro';
import RichText from './RichText.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getProjectSummaries } from '../lib/content';
import type { HomePageBlok, ProjectSummary } from '../types/storyblok';

interface Props {
  blok: HomePageBlok;
  /** Optional: pages pass the grid; via StoryblokComponent (preview) it self-fetches. */
  projects?: ProjectSummary[];
}

const { blok } = Astro.props;
const projects = Astro.props.projects ?? (await getProjectSummaries());
---

<div class="home" {...storyblokEditable(blok)}>
  <section class="home__intro">
    {blok.titre && <h1>{blok.titre}</h1>}
    {blok.intro && <RichText doc={blok.intro} />}
  </section>
  <ul class="project-grid">
    {
      projects.map((project) => (
        <li>
          <ProjectCard project={project} />
        </li>
      ))
    }
  </ul>
</div>
