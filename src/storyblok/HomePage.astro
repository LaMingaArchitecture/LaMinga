---
import { storyblokEditable } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import FullscreenCarousel from '../components/FullscreenCarousel.astro';
import type { HomePageBlok } from '../types/storyblok';

const { blok } = Astro.props as { blok: HomePageBlok };
// Ordered homepage slides (each links to a project and derives its title from it).
// The first slide loads eagerly (LCP); the rest lazy-load beyond the fold — see HomeSlide.
const slides = blok.carrousel ?? [];
---

<FullscreenCarousel
  ariaLabel="Projets à la une"
  slideCount={slides.length}
  {...storyblokEditable(blok)}
>
  {slides.map((slide, i) => <StoryblokComponent blok={slide} first={i === 0} />)}
</FullscreenCarousel>
