---
import { storyblokEditable } from '@storyblok/astro';
import ResponsiveMedia from './ResponsiveMedia.astro';
import { isResolved } from '../lib/content';
import type { HomeSlideBlok, ProjectBlok } from '../types/storyblok';

const { blok } = Astro.props as { blok: HomeSlideBlok };

// `projet` arrives resolved via HOME_RELATIONS; narrow to the resolved story.
const projet = isResolved(blok.projet) ? blok.projet : null;
const content = projet ? (projet.content as ProjectBlok) : null;
const href = projet ? `/projets/${projet.slug}` : undefined;
const titre = content
  ? [content.titre, content.ville, content.description_programme].filter(Boolean).join(' — ')
  : '';
const alt = blok.image_paysage?.alt ?? content?.titre ?? '';
---

<article
  class:list={['home-slide', { 'home-slide--clair': blok.titre_clair }]}
  {...storyblokEditable(blok)}
>
  <ResponsiveMedia
    imagePaysage={blok.image_paysage}
    imagePortrait={blok.image_portrait}
    video={blok.video}
    poster={blok.poster}
    alt={alt}
    loading="eager"
  />
  {
    titre &&
      (href ? (
        <a class="home-slide__title" href={href}>
          {titre}
        </a>
      ) : (
        <p class="home-slide__title">{titre}</p>
      ))
  }
</article>

<style>
  .home-slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
    scroll-snap-align: start;
  }
  .home-slide :global(img),
  .home-slide :global(video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .home-slide__title {
    position: absolute;
    left: 50%;
    bottom: var(--space-8);
    transform: translateX(-50%);
    max-width: min(90%, 50rem);
    margin: 0;
    padding: var(--space-2) var(--space-4);
    text-align: center;
    text-decoration: none;
    font-size: 0.9375rem;
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-paper) 92%, transparent);
    border-radius: var(--radius);
  }
  .home-slide--clair .home-slide__title {
    color: var(--color-paper);
    background: color-mix(in srgb, #000000 72%, transparent);
  }
</style>
