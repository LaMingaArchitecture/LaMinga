---
import { storyblokEditable } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import FullscreenCarousel from '../components/FullscreenCarousel.astro';
import ProjectHudCard from '../components/ProjectHudCard.astro';
import ProjectInfoOverlay from '../components/ProjectInfoOverlay.astro';
import ProjectRelatedBand from '../components/ProjectRelatedBand.astro';
import ProjectRecapSlide from '../components/ProjectRecapSlide.astro';
import { resolveRelated } from '../lib/content';
import type { ProjectBlok } from '../types/storyblok';

const { blok } = Astro.props as { blok: ProjectBlok };
const related = resolveRelated(blok);
const slides = blok.carrousel ?? [];
// The recap mosaic is only worth a slide when there are ≥2 visuals; it counts in the "X / N".
const showRecap = slides.length >= 2;
const slideCount = slides.length + (showRecap ? 1 : 0);
const hasRelated = related.length > 0;

// Data-sheet rows (info overlay), empty fields dropped so no blank rows render.
const data: Array<[string, string | undefined]> = [
  ["Maîtrise d'ouvrage", blok.maitre_ouvrage],
  ['Équipe', blok.equipe],
  ['Statut', blok.statut],
  ['m² SDP', blok.surface_sdp],
  ['Montant HT', blok.montant_ht],
  ['Divers', blok.divers],
];
const rows = data.filter(([, value]) => Boolean(value));
// The "+ infos" overlay only adds value beyond the card when there are extra facts to show.
const infosHasContent =
  rows.length > 0 || Boolean(blok.texte) || (blok.engagements?.length ?? 0) > 0;
---

<FullscreenCarousel
  controls="grouped"
  counter
  ariaLabel={blok.titre}
  slideCount={slideCount}
  {...storyblokEditable(blok)}
>
  {slides.map((slide, i) => <StoryblokComponent blok={slide} first={i === 0} />)}
  {showRecap && <ProjectRecapSlide slides={slides} />}

  <div class="project-hud" data-project-overlays slot="overlays">
    {infosHasContent && <ProjectInfoOverlay id="project-infos" blok={blok} rows={rows} />}
    {hasRelated && <ProjectRelatedBand id="project-similaires" related={related} />}

    <div class="project-hud__bar">
      <div class="project-hud__pills">
        {
          infosHasContent && (
            <button
              type="button"
              class="pill pill--infos"
              aria-expanded="false"
              aria-controls="project-infos"
              data-overlay-pill="infos"
            >
              <span class="pill__badge" aria-hidden="true" /> infos
            </button>
          )
        }
        {
          hasRelated && (
            <button
              type="button"
              class="pill pill--similaires"
              aria-expanded="false"
              aria-controls="project-similaires"
              data-overlay-pill="similaires"
            >
              <span class="pill__badge" aria-hidden="true" /> projets similaires
            </button>
          )
        }
      </div>
      <div class="project-hud__card">
        <ProjectHudCard
          titre={blok.titre}
          ville={blok.ville}
          programme={blok.description_programme}
        />
      </div>
    </div>
  </div>
</FullscreenCarousel>

<script>
  import '../scripts/project-overlays';
</script>

<style>
  /* HUD layer over the carousel: full-bleed, click-through except on its interactive children.
     --band-* bound the info/related overlays so they clear the floating header and the bottom bar. */
  .project-hud {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    /* Bounds for the info/related overlays. The card is hidden while an overlay is open, so the
       bottom only needs to clear the active pill + counter row. */
    --band-top: calc(var(--header-h-mobile) + var(--space-3));
    --band-bottom: 5.5rem;
    --band-x: var(--space-4);
  }

  /* Bottom bar: card centered above the pills row on mobile; pills · card · (counter) on desktop.
     z-index keeps pills clickable above an open overlay; the carousel counter sits above all of it. */
  .project-hud__bar {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-4);
    padding-bottom: max(var(--space-4), env(safe-area-inset-bottom));
    pointer-events: none;
  }
  .project-hud__bar > * {
    pointer-events: auto;
  }

  .project-hud__card {
    order: 1;
    align-self: center;
    max-width: 100%;
  }
  .project-hud__pills {
    order: 2;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    /* Keep the pills clear of the bottom-right counter on narrow screens. */
    padding-right: 4.5rem;
    pointer-events: none;
  }
  .project-hud__pills > * {
    pointer-events: auto;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 44px;
    padding: var(--space-1) var(--space-3) var(--space-1) var(--space-1);
    border: 0;
    border-radius: 999px;
    background: none;
    color: var(--hud-ink);
    font: inherit;
    font-size: 0.9375rem;
    cursor: pointer;
    touch-action: manipulation;
    filter: drop-shadow(0 1px 2px rgb(0 0 0 / 0.35));
  }
  /* The +/− sign is drawn as two centered bars (pixel-perfect, unlike a text glyph); the vertical
     bar collapses when the pill is expanded, so "+" becomes "−" purely from aria-expanded. */
  .pill__badge {
    position: relative;
    flex-shrink: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
  }
  .pill__badge::before,
  .pill__badge::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-paper);
    border-radius: 1px;
    transition: transform var(--transition);
  }
  .pill__badge::before {
    width: 0.8125rem;
    height: 2px;
  }
  .pill__badge::after {
    width: 2px;
    height: 0.8125rem;
  }
  .pill[aria-expanded='true'] .pill__badge::after {
    transform: translate(-50%, -50%) scaleY(0);
  }
  .pill--infos .pill__badge {
    background: var(--color-coral);
  }
  .pill--similaires .pill__badge {
    background: var(--couleur-bleu-clair);
  }

  /* While an overlay is open, take the persistent card and the other pill out of view so nothing
     overlaps the panels — only the active pill (now a "−") stays, as the close affordance. The card
     is hidden visually but kept in the a11y tree (sr-only, not display:none) so its <h1> — the page's
     only heading — is never removed while an overlay is open. */
  .project-hud[data-overlay-open] .project-hud__card {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
  .project-hud[data-overlay-open] .pill[aria-expanded='false'] {
    display: none;
  }

  @media (min-width: 48rem) {
    .project-hud {
      /* The desktop header's left zone is two *stacked* outlined buttons (Atelier / Projets), so it
         renders taller than --header-h; budget for that real height plus a gap so the info/related
         bands clear the floating transparent nav instead of tucking under it. */
      --band-top: calc(var(--header-h) + var(--space-8) + var(--space-6));
      --band-bottom: 5.5rem;
      --band-x: var(--space-6);
    }
    /* pills → col 1, card → col 2 (centered); col 3 stays empty to reserve the counter's corner. */
    .project-hud__bar {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: end;
      gap: var(--space-4);
      padding: var(--space-6);
    }
    .project-hud__card {
      order: 0;
      justify-self: center;
    }
    .project-hud__pills {
      order: 0;
      justify-self: start;
      align-self: end;
      padding-right: 0;
    }
  }
</style>
