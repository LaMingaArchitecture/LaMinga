---
import { storyblokEditable } from '@storyblok/astro';
import RichText from './RichText.astro';
import ProjectExplorer from '../components/ProjectExplorer.astro';
import { getProjectSummaries, getProgrammes, getThematiques } from '../lib/content';
import type { ProjectListBlok } from '../types/storyblok';

const { blok } = Astro.props as { blok: ProjectListBlok };
// `[]` when no project is published — the grid/filter render empty by design (a
// missing *page* shows ContentNotice; an agency with zero projects is a valid state).
const projects = await getProjectSummaries();
const programmes = await getProgrammes();
const thematiques = await getThematiques();
---

<div class="project-list" {...storyblokEditable(blok)}>
  <header class="visually-hidden">
    <h1>{blok.titre}</h1>
    {blok.intro && <RichText doc={blok.intro} />}
  </header>
  <ProjectExplorer projects={projects} programmes={programmes} thematiques={thematiques} />
</div>

<!-- The Projets page: a beige-10 fullscreen frame that scrolls vertically. The explorer's filter
     + tool rows stay pinned (sticky) while the Vignettes rail / Liste table scroll. The design puts
     the title only in the nav, so the page heading is kept for a11y/SEO but visually hidden. -->
<style>
  .project-list {
    height: 100%;
    overflow-y: auto;
    /* The Vignettes rail and the Liste table own their horizontal scroll; the page never does
       (so the sticky filters can't be dragged sideways). */
    overflow-x: hidden;
    padding: var(--space-4) var(--space-4) var(--space-8);
    background: var(--color-beige-10);
  }

  /* Mobile: don't create an internal scroll container — let the whole document scroll so the footer
     flows below (see the body rule in global.css). The sticky filters then anchor to the document
     scroll, offset below the pinned header (ProjectExplorer.astro). */
  @media (max-width: 47.999rem) {
    .project-list {
      height: auto;
      overflow: visible;
    }
  }
</style>
