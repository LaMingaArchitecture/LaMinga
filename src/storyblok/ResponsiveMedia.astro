---
// Presentational helper (not a registered blok): renders a responsive picture or a
// decorative muted-loop video from the shared media fields. Centralizes the CSP
// media-src surface and the jsx-a11y `<track>` mitigation for every project/home video.
import { sbImageW, sbSrcset, SIZES_FULLSCREEN, HERO_IMG_WIDTH, POSTER_WIDTH } from '../lib/image';
import type { StoryblokAsset } from '../types/storyblok';

interface Props {
  imagePaysage?: StoryblokAsset;
  imagePortrait?: StoryblokAsset;
  video?: StoryblokAsset;
  poster?: StoryblokAsset;
  alt: string;
  loading?: 'lazy' | 'eager';
  class?: string;
}

const {
  imagePaysage,
  imagePortrait,
  video,
  poster,
  alt,
  loading = 'lazy',
  class: className,
} = Astro.props;

// The eager visual is the page's LCP → mark it high priority; the rest lazy-load.
const eager = loading === 'eager';
// Video src uses the raw filename (an mp4 asset, not transformable by the image service). The
// widths (HERO_IMG_WIDTH, POSTER_WIDTH) and 100vw sizes come from src/lib/image.ts so this branch's
// URLs stay byte-identical to lcpPreload's (src/lib/media.ts) — no double-download of the LCP.
const videoSrc = video?.filename;
const posterSrc = poster?.filename ? sbImageW(poster.filename, POSTER_WIDTH) : undefined;
const portrait = imagePortrait?.filename;
const paysage = imagePaysage?.filename ?? portrait;
---

{
  videoSrc ? (
    <video
      class:list={['responsive-media', 'responsive-media--video', className]}
      src={videoSrc}
      poster={posterSrc}
      muted
      autoplay
      loop
      playsinline
      preload={loading === 'eager' ? 'auto' : 'none'}
      aria-label={alt || undefined}
    >
      {/* Decorative, muted loop with no dialogue — a valid empty VTT captions track
          satisfies jsx-a11y while keeping the markup HTML-valid (track needs a src). */}
      <track kind="captions" src="/media/empty.vtt" srclang="fr" label="Sans paroles" />
    </video>
  ) : paysage ? (
    <picture class:list={['responsive-media', className]}>
      {portrait && (
        <source media="(max-width: 640px)" srcset={sbSrcset(portrait)} sizes={SIZES_FULLSCREEN} />
      )}
      <img
        src={sbImageW(paysage, HERO_IMG_WIDTH)}
        srcset={sbSrcset(paysage)}
        sizes={SIZES_FULLSCREEN}
        alt={alt}
        loading={loading}
        fetchpriority={eager ? 'high' : undefined}
        decoding="async"
      />
    </picture>
  ) : null
}
