---
import { renderRichText } from '@storyblok/astro';
import { sanitizeRichTextHtml } from '../lib/url';
import type { RichText } from '../types/storyblok';

interface Props {
  doc?: RichText;
}

const { doc } = Astro.props;
// Sanitize link schemes (drop javascript:/data:/… hrefs) before injecting the richtext.
const html = doc ? sanitizeRichTextHtml(renderRichText(doc)) : '';
---

{html && <div class="richtext" set:html={html} />}
